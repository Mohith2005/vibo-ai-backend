{
  "expo": {
    "name": "Vibo AI",
    "slug": "videflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/vibo_icon.png",
    "scheme": "vibo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mohit.faceemotiondetection",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "compileSdkVersion": 35,
      "package": "com.mohit.faceemotiondetection",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "VIBRATE",
        "READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "enableJetifier": true,
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      [
        "@react-native-voice/voice",
        {
          "microphonePermission": "Allow Vibo AI to access the microphone for voice commands.",
          "speechRecognitionPermission": "Allow Vibo AI to recognize your voice tone."
        }
      ],
      "./plugins/withAndroidXFix"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ae24b4e1-56ff-4f89-b59f-b1a0d9c07ab3"
      }
    },
    "owner": "mohith20052"
  }
}
