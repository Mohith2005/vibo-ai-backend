{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "local"
  },

  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_USE_DEV_SERVER": "true"
      }
    },

    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_NETWORK_MODE": "auto"
      }
    },

    "production": {
      "distribution": "store",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_NETWORK_MODE": "auto"
      }
    }
  },

  "submit": {
    "production": {}
  }
}
